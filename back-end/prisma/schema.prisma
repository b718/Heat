// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Song {
  id        String   @id
  name      String
  genres    String[]
  createdAt DateTime @default(now())

  // Relations
  skips           Skip[]
  artists         Artist[]
  songGenreLabels SongGenreLabel[]
}

model SongGenreLabel {
  id             String   @id @default(uuid())
  labelledGenres String[]
  createdAt      DateTime @default(now())

  // Relations
  songId String
  song   Song   @relation(fields: [songId], references: [id])
}

model Artist {
  id        String   @id
  name      String
  genres    String[]
  createdAt DateTime @default(now())

  // Relations
  songs             Song[]
  relatedTo         ArtistToArtist[]   @relation("SourceArtist")
  relatedFrom       ArtistToArtist[]   @relation("RelatedArtist")
  artistGenreLabels ArtistGenreLabel[]
}

model ArtistGenreLabel {
  id             String   @id @default(uuid())
  labelledGenres String[]
  createdAt      DateTime @default(now())

  // Relations
  artistId String
  artist   Artist @relation(fields: [artistId], references: [id])
}

model ArtistToArtist {
  id              String @id @default(uuid())
  sourceArtistId  String
  relatedArtistId String

  // Relations
  source  Artist @relation("SourceArtist", fields: [sourceArtistId], references: [id])
  related Artist @relation("RelatedArtist", fields: [relatedArtistId], references: [id])
}

model Skip {
  id          String   @id @default(uuid())
  direction   String
  currentTime Int
  duration    Int
  createdAt   DateTime @default(now())

  // Relations
  songId String
  song   Song   @relation(fields: [songId], references: [id])
}
