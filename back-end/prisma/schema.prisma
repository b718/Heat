// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Song {
  id String @id
  name String
  genres String[]

  // Relations
  skips Skip[]
  artists Artist[]
}

model Artist {
  id String @id
  name String
  genres String[]

  // Relations
  songs Song[]
  relatedTo ArtistToArtist[] @relation("SourceArtist")
  relatedFrom ArtistToArtist[] @relation("RelatedArtist")
}

model ArtistToArtist {
  id String @id @default(uuid())
  sourceArtistId String
  relatedArtistId String

  //Relations
  source  Artist @relation("SourceArtist",  fields: [sourceArtistId],  references: [id])
  related Artist @relation("RelatedArtist", fields: [relatedArtistId], references: [id])
}

model Skip {
  id String @id @default(uuid())
  direction String
  currentTime Int
  duration Int

  songId String
  song   Song @relation(fields: [songId], references: [id])
}

